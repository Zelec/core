{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": [
    "config:recommended",
    ":semanticCommitTypeAll(chore)"
  ],
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true,
    "schedule": [
      "before 4am on monday"
    ]
  },
  "automergeSchedule": [
    "before 4am on tuesday"
  ],
  "nix": {
    "enabled": true
  },
  "packageRules": [
    {
      "lockFileMaintenance": {
        "enabled": true
      },
      "matchDepTypes": [
        "lockfile"
      ],
      "matchManagers": [
        "nix"
      ],
      "rangeStrategy": "pin"
    }
  ]
}